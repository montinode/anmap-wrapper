        gap: 25px;
        margin-bottom: 30px;
      }
      
      .card {
        background: rgba(15, 28, 46, 0.9);
        border: 2px solid #00d9ff;
        border-radius: 12px;
        padding: 20px;
        transition: all 0.3s ease;
        box-shadow: 0 0 20px rgba(0, 217, 255, 0.3);
      }
      
      .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 0 40px rgba(0, 217, 255, 0.6);
        border-color: #ffd700;
      }
      
      .card h3 {
        color: #ffd700;
        margin-bottom: 15px;
        font-size: 1.3em;
        text-shadow: 0 0 10px #ffd700;
      }
      
      .card img {
        width: 100%;
        height: 250px;
        object-fit: cover;
        border: 2px solid #00d9ff;
        border-radius: 8px;
        margin-bottom: 15px;
      }
      
      .card ul {
        list-style: none;
        padding-left: 0;
      }
      
      .card li {
        color: #00ff00;
        padding: 5px 0;
        font-size: 0.9em;
      }
      
      .card li::before {
        content: "◉ ";
        color: #00d9ff;
      }
      
      .format-section {
        background: rgba(0, 0, 0, 0.8);
        border: 3px solid #ff0000;
        border-radius: 15px;
        padding: 30px;
        margin-bottom: 30px;
      }
      
