        text-align: center;
        font-size: 2em;
        margin-bottom: 20px;
        text-shadow: 0 0 15px #ff0000;
      }
      
      .format-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
      }
      
      .format-card {
        background: linear-gradient(135deg, #1a1a3e 0%, #0a1628 100%);
        border: 2px solid #00ffff;
        border-radius: 10px;
        padding: 20px;
        text-align: center;
        transition: all 0.3s ease;
      }
      
      .format-card:hover {
        transform: scale(1.05);
        box-shadow: 0 0 30px rgba(0, 255, 255, 0.6);
      }
      
      .format-card h4 {
        color: #00ffff;
        font-size: 1.5em;
        margin-bottom: 10px;
      }
      
      .format-card p {
        color: #ffffff;
        font-size: 0.9em;
        margin-bottom: 15px;
      }
      
      .download-btn {
        background: linear-gradient(135deg, #00ff00 0%, #00cc00 100%);
        color: #000000;
        border: none;
        padding: 12px 25px;
        border-radius: 8px;
        font-weight: bold;
        cursor: pointer;
        font-size: 1em;
        transition: all 0.3s ease;
        text-transform: uppercase;
      }
      
      .download-btn:hover {
        background: linear-gradient(135deg, #00ffff 0%, #00cccc 100%);
        box-shadow: 0 0 20px rgba(0, 255, 255, 0.8);
        transform: scale(1.1);
      }
      
      .status-bar {
        background: rgba(139, 0, 0, 0.9);
        border: 2px solid #ffd700;
        border-radius: 10px;
        padding: 15px;
        text-align: center;
        margin-top: 30px;
      }
      
      .status-bar p {
        color: #ffffff;
        font-size: 1.1em;
        font-weight: bold;
      }
      
      .energy-indicator {
        display: inline-block;
        width: 15px;
        height: 15px;
        background: #00ff00;
        border-radius: 50%;
        margin-right: 10px;
        animation: pulse 1.5s infinite;
        box-shadow: 0 0 10px #00ff00;
      }
      
      @keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(1.2); }
      }
      
      .coordinates {
        background: rgba(0, 0, 0, 0.9);
        border: 2px solid #00ff00;
        border-radius: 8px;
        padding: 15px;
        margin-top: 20px;
        font-family: 'Courier New', monospace;
